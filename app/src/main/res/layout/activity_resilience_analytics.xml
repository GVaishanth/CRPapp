<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:menu="@menu/analytics_menu"
            app:title="@string/title_resilience_analytics"
            app:titleCentered="false" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Executive Summary Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Executive Resilience Report"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Historical analysis of predictive anomaly monitoring, atomic state protection, and automated crash recovery outcomes."
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <!-- SECTION 1: Framework Overview -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/header_framework_overview"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorPrimary" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:strokeColor="@color/md_theme_light_outlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_protected_sessions"
                                android:textAppearance="?attr/textAppearanceLabelSmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                            <TextView
                                android:id="@+id/overviewSessions"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="?attr/textAppearanceHeadlineMedium"
                                android:textColor="?attr/colorPrimary"
                                tools:text="12" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_total_checkpoints"
                                android:textAppearance="?attr/textAppearanceLabelSmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                            <TextView
                                android:id="@+id/overviewCheckpoints"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="?attr/textAppearanceHeadlineMedium"
                                android:textColor="?attr/colorPrimary"
                                tools:text="48" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_total_recoveries"
                                android:textAppearance="?attr/textAppearanceLabelSmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                            <TextView
                                android:id="@+id/overviewRecoveries"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="?attr/textAppearanceHeadlineMedium"
                                android:textColor="?attr/colorPrimary"
                                tools:text="5" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_recovery_success_rate"
                                android:textAppearance="?attr/textAppearanceLabelSmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                            <TextView
                                android:id="@+id/overviewSuccessRate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="?attr/textAppearanceHeadlineMedium"
                                android:textColor="@color/resilience_healthy"
                                tools:text="100%" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="?attr/colorOutlineVariant" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/label_framework_version"
                            android:textAppearance="?attr/textAppearanceBodyMedium" />
                        <TextView
                            android:id="@+id/overviewVersion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2.0-phase8"
                            android:textAppearance="?attr/textAppearanceTitleSmall" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECTION 2: Prediction Analytics -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/header_prediction_analytics"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorPrimary" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:strokeColor="@color/md_theme_light_outlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/label_avg_anomaly_score"
                            android:textAppearance="?attr/textAppearanceLabelLarge"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                        <TextView
                            android:id="@+id/predAvgScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="?attr/textAppearanceHeadlineSmall"
                            android:textColor="?attr/colorPrimary"
                            tools:text="0.142" />
                    </LinearLayout>

                    <!-- Risk Tier Distribution -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/label_risk_tier_distribution"
                        android:textAppearance="?attr/textAppearanceLabelMedium" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="8dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="72dp"
                                android:layout_height="wrap_content"
                                android:text="LOW"
                                android:textAppearance="?attr/textAppearanceBodySmall" />
                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/tierLowBar"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                app:indicatorColor="@color/resilience_healthy"
                                app:trackThickness="6dp"
                                android:max="100" />
                            <TextView
                                android:id="@+id/tierLowText"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                tools:text="92%" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="6dp">
                            <TextView
                                android:layout_width="72dp"
                                android:layout_height="wrap_content"
                                android:text="ELEVATED"
                                android:textAppearance="?attr/textAppearanceBodySmall" />
                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/tierElevatedBar"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                app:indicatorColor="@color/resilience_elevated"
                                app:trackThickness="6dp"
                                android:max="100" />
                            <TextView
                                android:id="@+id/tierElevatedText"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                tools:text="6%" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="6dp">
                            <TextView
                                android:layout_width="72dp"
                                android:layout_height="wrap_content"
                                android:text="HIGH"
                                android:textAppearance="?attr/textAppearanceBodySmall" />
                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/tierHighBar"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                app:indicatorColor="@color/resilience_high"
                                app:trackThickness="6dp"
                                android:max="100" />
                            <TextView
                                android:id="@+id/tierHighText"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                tools:text="2%" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Metric Contributions -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="@string/label_metric_contributions"
                        android:textAppearance="?attr/textAppearanceLabelMedium" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="8dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="72dp"
                                android:layout_height="wrap_content"
                                android:text="@string/label_memory"
                                android:textAppearance="?attr/textAppearanceBodySmall" />
                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/contribMemBar"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                app:trackThickness="4dp"
                                android:max="100" />
                            <TextView
                                android:id="@+id/contribMemText"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                tools:text="58%" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">
                            <TextView
                                android:layout_width="72dp"
                                android:layout_height="wrap_content"
                                android:text="@string/label_cpu"
                                android:textAppearance="?attr/textAppearanceBodySmall" />
                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/contribCpuBar"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                app:trackThickness="4dp"
                                android:max="100" />
                            <TextView
                                android:id="@+id/contribCpuText"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                tools:text="18%" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">
                            <TextView
                                android:layout_width="72dp"
                                android:layout_height="wrap_content"
                                android:text="@string/label_render"
                                android:textAppearance="?attr/textAppearanceBodySmall" />
                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/contribRenderBar"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                app:trackThickness="4dp"
                                android:max="100" />
                            <TextView
                                android:id="@+id/contribRenderText"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                tools:text="14%" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">
                            <TextView
                                android:layout_width="72dp"
                                android:layout_height="wrap_content"
                                android:text="@string/label_scroll"
                                android:textAppearance="?attr/textAppearanceBodySmall" />
                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/contribScrollBar"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                app:trackThickness="4dp"
                                android:max="100" />
                            <TextView
                                android:id="@+id/contribScrollText"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                tools:text="10%" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Rolling Trends & Trigger Reasons -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="@string/label_rolling_trends"
                        android:textAppearance="?attr/textAppearanceLabelMedium" />
                    <TextView
                        android:id="@+id/predRollingTrends"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="Score stable over last 60 samples. Peak stress observed in Memory." />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/label_trigger_reasons"
                        android:textAppearance="?attr/textAppearanceLabelMedium" />
                    <TextView
                        android:id="@+id/predTriggerReasons"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="1. memory rising (68%)\n2. cpu rising (32%)" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECTION 3: Protection Analytics -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/header_protection_analytics"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorPrimary" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:strokeColor="@color/md_theme_light_outlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_checkpoints_per_session"
                                android:textAppearance="?attr/textAppearanceLabelSmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                            <TextView
                                android:id="@+id/protCpPerSession"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="?attr/textAppearanceHeadlineMedium"
                                android:textColor="?attr/colorPrimary"
                                tools:text="4.2" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_avg_checkpoint_age"
                                android:textAppearance="?attr/textAppearanceLabelSmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                            <TextView
                                android:id="@+id/protAvgAge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="?attr/textAppearanceHeadlineMedium"
                                android:textColor="?attr/colorPrimary"
                                tools:text="14.5s" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="@string/label_trigger_distribution"
                        android:textAppearance="?attr/textAppearanceLabelMedium" />
                    <TextView
                        android:id="@+id/protTriggerDist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="AUTO_INTERVAL: 64% • AUTO_ANOMALY: 22% • MANUAL: 14%" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/label_manual_vs_auto"
                        android:textAppearance="?attr/textAppearanceLabelMedium" />
                    <TextView
                        android:id="@+id/protManualVsAuto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="14% Manual / 86% Automatic" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="@string/label_checkpoint_timeline"
                        android:textAppearance="?attr/textAppearanceLabelMedium" />
                    <LinearLayout
                        android:id="@+id/protTimeline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECTION 4: Recovery Analytics -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/header_recovery_analytics"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorPrimary" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:strokeColor="@color/md_theme_light_outlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_avg_recovery_duration"
                                android:textAppearance="?attr/textAppearanceLabelSmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                            <TextView
                                android:id="@+id/recAvgDuration"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="?attr/textAppearanceHeadlineMedium"
                                android:textColor="?attr/colorPrimary"
                                tools:text="824 ms" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_avg_age_at_recovery"
                                android:textAppearance="?attr/textAppearanceLabelSmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                            <TextView
                                android:id="@+id/recAvgAgeAtRec"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="?attr/textAppearanceHeadlineMedium"
                                android:textColor="?attr/colorPrimary"
                                tools:text="3.2s" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="@string/label_normal_vs_fallback"
                        android:textAppearance="?attr/textAppearanceLabelMedium" />
                    <TextView
                        android:id="@+id/recNormalVsFallback"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="100% Normal / 0% Fallback" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="@string/label_recovery_timeline"
                        android:textAppearance="?attr/textAppearanceLabelMedium" />
                    <LinearLayout
                        android:id="@+id/recTimeline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Space
                android:layout_width="match_parent"
                android:layout_height="32dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>

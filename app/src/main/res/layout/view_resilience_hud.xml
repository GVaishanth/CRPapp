<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/hudCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/md_theme_light_outlineVariant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Collapsed summary row -->
        <LinearLayout
            android:id="@+id/hudSummaryRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:focusable="true"
            android:clickable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/hudShieldIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_shield_check" />

            <TextView
                android:id="@+id/hudRiskLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                tools:text="Protected • Monitoring" />

            <TextView
                android:id="@+id/hudScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorPrimary"
                tools:text="0.18" />

            <ImageView
                android:id="@+id/hudExpandIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/arrow_down_float"
                android:contentDescription="Expand" />
        </LinearLayout>

        <!-- Anomaly bar -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/hudAnomalyBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:indicatorColor="@color/resilience_healthy"
            app:trackColor="@color/md_theme_light_surfaceVariant"
            app:trackThickness="6dp"
            android:max="100"
            android:progress="18"
            tools:progress="18" />

        <!-- Expanded details -->
        <LinearLayout
            android:id="@+id/hudDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_checkpoint_readiness"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                    <TextView
                        android:id="@+id/hudCheckpointStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        tools:text="Ready" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_last_checkpoint"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                    <TextView
                        android:id="@+id/hudLastCheckpoint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        tools:text="4s ago • Page 12" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_current_page"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                    <TextView
                        android:id="@+id/hudCurrentPage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        tools:text="12 / 48" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_monitoring"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                    <TextView
                        android:id="@+id/hudMonitoringStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/resilience_healthy"
                        tools:text="Active • 1 Hz" />
                </LinearLayout>
            </LinearLayout>

            <!-- Metrics Breakdown - Phase 4 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/label_metrics_breakdown"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="6dp">

                <!-- Memory -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:text="Memory"
                        android:textAppearance="?attr/textAppearanceBodySmall" />
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/metricMemoryBar"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        app:trackThickness="4dp"
                        android:max="100"
                        android:progress="0" />
                    <TextView
                        android:id="@+id/metricMemoryText"
                        android:layout_width="64dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="0.42" />
                </LinearLayout>

                <!-- CPU -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:text="CPU"
                        android:textAppearance="?attr/textAppearanceBodySmall" />
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/metricCpuBar"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        app:trackThickness="4dp"
                        android:max="100"
                        android:progress="0" />
                    <TextView
                        android:id="@+id/metricCpuText"
                        android:layout_width="64dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="0.18" />
                </LinearLayout>

                <!-- Render -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:text="Render"
                        android:textAppearance="?attr/textAppearanceBodySmall" />
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/metricRenderBar"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        app:trackThickness="4dp"
                        android:max="100"
                        android:progress="0" />
                    <TextView
                        android:id="@+id/metricRenderText"
                        android:layout_width="64dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="0.04" />
                </LinearLayout>

                <!-- Scroll -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:text="Scroll"
                        android:textAppearance="?attr/textAppearanceBodySmall" />
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/metricScrollBar"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        app:trackThickness="4dp"
                        android:max="100"
                        android:progress="0" />
                    <TextView
                        android:id="@+id/metricScrollText"
                        android:layout_width="64dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="0.12" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/hudTriggerReason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone"
                tools:text="memory rising" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
